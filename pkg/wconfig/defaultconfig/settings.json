{
    "ai:preset": "ai@global",
    "ai:model": "gpt-5-mini",
    "ai:maxtokens": 4000,
    "ai:timeoutms": 60000,
    "app:defaultnewblock": "preview",
    "app:externalterminal": "auto",
    "app:confirmquit": false,
    "autoupdate:enabled": true,
    "autoupdate:installonquit": true,
    "autoupdate:intervalms": 3600000,
    "conn:askbeforewshinstall": true,
    "conn:wshenabled": true,
    "editor:fontsize": 15,
    "editor:minimapenabled": true,
    "markdown:fixedfontsize": 13,
    "markdown:fontsize": 15,
    "tab:preset": "bg@white",
    "web:defaulturl": "https://github.com/wavetermdev/waveterm",
    "web:defaultsearch": "https://www.google.com/search?q={query}",
    "window:bgcolor": "#ffffff",
    "window:tilegapsize": 3,
    "window:maxtabcachesize": 10,
    "window:nativetitlebar": true,
    "window:disablehardwareacceleration": true,
    "window:magnifiedblockopacity": 0.6,
    "window:magnifiedblocksize": 0.9,
    "window:magnifiedblockblurprimarypx": 10,
    "window:fullscreenonlaunch": false,
    "window:magnifiedblockblursecondarypx": 2,
    "window:confirmclose": false,
    "window:savelastwindow": true,
    "telemetry:enabled": true,
    "term:theme": "default-light",
    "term:disablewebgl": true,
    "term:bellsound": false,
    "term:bellindicator": true,
    "term:copyonselect": true,
    "term:durable": false,
    "waveai:showcloudmodes": true,
    "waveai:defaultmode": "waveai@balanced"
}
